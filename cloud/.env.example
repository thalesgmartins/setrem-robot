# ============================================================
# Variáveis do ambiente Cloud. Copie para ".env" (mesma pasta) e preencha.
# O .env NÃO vai para o git (está no .gitignore).
#   cp .env.example .env
# ============================================================

# --- Broker MQTT remoto ---
# Usuário/senha que o ingestor usa para assinar a telemetria. Use o MESMO par
# criado no arquivo passwd (ver scripts/gen-mosquitto-passwd.sh) — pode ser o
# próprio usuário da bridge do Pi.
MQTT_USERNAME=piev
MQTT_PASSWORD=troque-esta-senha

# --- TimescaleDB ---
PGUSER=robo
PGPASSWORD=troque-esta-senha
PGDATABASE=robo
